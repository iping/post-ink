{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npx prisma generate",
  "buildCommand": "npx prisma db push --skip-generate",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
