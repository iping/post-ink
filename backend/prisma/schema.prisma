// Post.Ink - Tattoo Artists, Studios & Customers
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ----- Tattoo Artist -----
model TattooArtist {
  id               String   @id @default(cuid())
  name             String
  shortDescription String?
  experiences      String?  // years or text description
  speciality       String?  // e.g. "Black & Grey", "Japanese", "Realism"
  rate             Float?   // hourly rate in IDR
  photos           String   // JSON array of image URLs/paths
  portfolio        String   // JSON array of portfolio image URLs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  availability ArtistAvailability[]
  bookings     Booking[]
  commissions  StudioCommission[]
  reviews      Review[]
}

// Artist availability slots (date + time range)
model ArtistAvailability {
  id          String       @id @default(cuid())
  artistId    String
  artist      TattooArtist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  date        String       // YYYY-MM-DD
  startTime   String       // e.g. "09:00"
  endTime     String       // e.g. "17:00"
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([artistId, date, startTime])
  @@index([artistId])
  @@index([date])
}

// ----- Tattoo Studio -----
model TattooStudio {
  id         String   @id @default(cuid())
  name       String
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  bookings   Booking[]
  commissions StudioCommission[]
}

// ----- Customer -----
model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
  reviews   Review[]
}

// ----- Booking (Studio: manage booking process) -----
model Booking {
  id          String        @id @default(cuid())
  artistId    String
  artist      TattooArtist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  studioId    String?
  studio      TattooStudio?  @relation(fields: [studioId], references: [id], onDelete: SetNull)
  date        String        // YYYY-MM-DD
  startTime   String
  endTime     String
  status      String        @default("pending") // pending, confirmed, completed, cancelled
  totalAmount Float?        // agreed total price; remaining = totalAmount - sum(payments)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payments    Payment[]
  review      Review?

  @@index([artistId])
  @@index([customerId])
  @@index([date])
}

// ----- Payment (Studio: manage payment process) -----
model Payment {
  id                 String   @id @default(cuid())
  bookingId          String?
  booking            Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  amount             Float
  currency           String   @default("IDR")
  status             String   @default("pending") // pending, completed, refunded
  type               String?  // down_payment, final, other
  method             String?  // BCA, Mandiri, BNI, Credit Card, Cash
  transferDestination String? // account number or reference (e.g. BCA 1234567890)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([bookingId])
}

// ----- Studio commission: % agreed between artist and studio -----
model StudioCommission {
  id                String       @id @default(cuid())
  studioId          String
  studio            TattooStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  artistId          String
  artist            TattooArtist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  commissionPercent Float        // studio takes this % of booking total; artist gets the rest
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([studioId, artistId])
  @@index([studioId])
  @@index([artistId])
}

// ----- Speciality (master list for artist speciality picker) -----
model Speciality {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----- Review (customer feedback after completed booking) -----
model Review {
  id         String        @id @default(cuid())
  bookingId  String        @unique
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  artistId   String
  artist     TattooArtist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  rating     Int           // 1–5 stars
  comment    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([artistId])
  @@index([customerId])
}
