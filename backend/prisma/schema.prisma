// Post.Ink - Tattoo Artists, Studios & Customers
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ----- Platform User (login to management) -----
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("staff") // admin, staff
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ----- Tattoo Artist -----
model TattooArtist {
  id               String   @id @default(cuid())
  name             String
  shortDescription String?
  experiences      String?  // years or text description
  speciality       String?  // e.g. "Black & Grey", "Japanese", "Realism"
  rate             Float?   // hourly rate in IDR
  photos           String   // JSON array of image URLs/paths
  portfolio        String   // JSON array of portfolio image URLs
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  availability ArtistAvailability[]
  bookings     Booking[]
  commissions  StudioCommission[]
  referredLeads Customer[] @relation("LeadReferralArtist")
  paymentDestinations PaymentDestination[] @relation("ArtistPaymentDestinations")
  receivedPayments Payment[] @relation("ArtistReceivedPayments")
}

// Artist availability slots (date + time range)
model ArtistAvailability {
  id          String       @id @default(cuid())
  artistId    String
  artist      TattooArtist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  date        String       // YYYY-MM-DD
  startTime   String       // e.g. "09:00"
  endTime     String       // e.g. "17:00"
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([artistId, date, startTime])
  @@index([artistId])
  @@index([date])
}

// ----- Tattoo Studio -----
model TattooStudio {
  id         String   @id @default(cuid())
  name       String
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  bookings   Booking[]
  commissions StudioCommission[]
  paymentDestinations PaymentDestination[] @relation("StudioPaymentDestinations")
  receivedPayments Payment[] @relation("StudioReceivedPayments")
}

// ----- Customer -----
model Customer {
  id        String   @id // 6-digit numeric, set in app
  name      String
  email     String?
  phone     String?
  type      String   @default("customer") // lead | customer
  leadSource String?
  referredArtistId String?
  referredArtist TattooArtist? @relation("LeadReferralArtist", fields: [referredArtistId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]

  @@index([type])
  @@index([leadSource])
  @@index([referredArtistId])
}

// ----- Booking (Studio: manage booking process) -----
model Booking {
  id          String        @id @default(cuid())
  shortCode   String?       @unique // 5-char alphanumeric for display/copy
  artistId    String
  artist      TattooArtist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  studioId    String?
  studio      TattooStudio?  @relation(fields: [studioId], references: [id], onDelete: SetNull)
  date        String        // YYYY-MM-DD
  startTime   String
  endTime     String
  status       String        @default("Unpaid")  // Paid = payment evidence recorded; Unpaid = not yet paid
  pricingType  String?       // "fixed" | "hourly": fixed = totalAmount is final; hourly = total from projects (hours × rate, accumulative)
  totalAmount  Float?        // agreed total when pricingType=fixed; when hourly, total computed from projects
  placement    String?       // body placement e.g. Arm, Back, Chest
  preference  String?       // customer reference / preference (style, image ref, etc.)
  projectName String?       // e.g. "Maya Chen – Andi Pratama – 1"
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payments    Payment[]
  projects    Project[]

  @@index([artistId])
  @@index([customerId])
  @@index([date])
}

// ----- Project (work per booking; one booking can have multiple projects; each project has sessions) -----
model Project {
  id           String    @id // 6-digit numeric, set in app
  bookingId    String
  booking      Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name         String    // e.g. "Alpha"
  pricingType  String    // "fixed" | "hourly"
  fixedAmount  Float?    // agreed total when pricingType = fixed (admin-defined, customer agreed)
  hourlyRate   Float?    // IDR per hour when pricingType = hourly (artist–customer agreement)
  agreedHours  Float?    // optional: agreed hours when hourly (total = hourlyRate * agreedHours)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([bookingId])
}

// ----- Session (each project has minimum 1 session; one session = one date/time block) -----
model Session {
  id           String    @id // 6-digit numeric, set in app
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date         String    // YYYY-MM-DD
  startTime    String    // e.g. "09:00"
  endTime      String    // e.g. "12:00"
  actualHours  Float?    // optional: actual hours (for hourly billing)
  notes        String?
  status       String    @default("scheduled") // scheduled | in_progress | paused | completed
  startedAt    DateTime? // when user clicked Start session
  pausedAt     DateTime? // when user clicked Pause
  completedAt  DateTime? // when user clicked Stop
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId])
}

// ----- Payment (Studio: manage payment process) -----
model Payment {
  id                 String   @id @default(cuid())
  bookingId          String?
  booking            Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  paymentDestinationId String?
  paymentDestination PaymentDestination? @relation(fields: [paymentDestinationId], references: [id], onDelete: SetNull)
  amount             Float
  currency           String   @default("IDR")
  status             String   @default("pending") // pending, completed, refunded
  type               String?  // down_payment, final, other
  method             String?  // BCA, Mandiri, BNI, Credit Card, Cash
  transferDestination String? // account number or reference (e.g. BCA 1234567890)
  receiverType       String? // studio | artist
  receiverStudioId   String?
  receiverStudio     TattooStudio? @relation("StudioReceivedPayments", fields: [receiverStudioId], references: [id], onDelete: SetNull)
  receiverArtistId   String?
  receiverArtist     TattooArtist? @relation("ArtistReceivedPayments", fields: [receiverArtistId], references: [id], onDelete: SetNull)
  evidenceUrl        String?  // receipt / payment proof image URL
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([bookingId])
  @@index([paymentDestinationId])
  @@index([receiverType])
  @@index([receiverStudioId])
  @@index([receiverArtistId])
}

// ----- Studio commission: % agreed between artist and studio -----
model StudioCommission {
  id                String       @id @default(cuid())
  studioId          String
  studio            TattooStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  artistId          String
  artist            TattooArtist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  commissionPercent Float        // studio takes this % of booking total; artist gets the rest
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([studioId, artistId])
  @@index([studioId])
  @@index([artistId])
}

// ----- Payment destination (where booking fee can be paid: Bank, Credit Card, Cash) -----
model PaymentDestination {
  id        String   @id @default(cuid())
  name      String   // Bank Name or display name (e.g. "BCA", "Mandiri")
  account   String?  // Bank Account or reference (e.g. "1234567890")
  type      String   // "Bank" | "Credit Card" | "Cash"
  ownerType String   // studio | artist
  studioId  String?
  studio    TattooStudio? @relation("StudioPaymentDestinations", fields: [studioId], references: [id], onDelete: SetNull)
  artistId  String?
  artist    TattooArtist? @relation("ArtistPaymentDestinations", fields: [artistId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payments  Payment[]

  @@index([type])
  @@index([isActive])
  @@index([ownerType])
  @@index([studioId])
  @@index([artistId])
}

// ----- Speciality (master list for artist speciality picker) -----
model Speciality {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

