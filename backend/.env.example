# PostgreSQL (Neon on Vercel, or local Docker Postgres for development)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

PORT=3001
JWT_SECRET=your-secret-key-change-in-production

# Optional: public API base for upload URLs (set automatically on Vercel via VERCEL_URL)
# API_PUBLIC_URL=https://your-api.vercel.app

# Vercel Blob (auto-provisioned when Blob storage is linked to the project)
# BLOB_READ_WRITE_TOKEN=
